# Copy to infra/.env and edit before `docker compose up -d`.

# Domain — points to your VDS public IP via DNS A record.
# Use `localhost` for local testing (Caddy will serve plain HTTP).
DOMAIN=chat.example.com
ACME_EMAIL=admin@example.com

# Public URLs derived from DOMAIN. Override only if you split api/web on different hosts.
PUBLIC_URL=https://chat.example.com
API_PUBLIC_URL=https://chat.example.com

# Postgres
POSTGRES_DB=chatvds
POSTGRES_USER=chatvds
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# Auth — generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_at_least_32_characters_long_random_string

# File storage: 'local' (Docker volume) or 'minio' (S3-compatible)
STORAGE_DRIVER=local
MAX_UPLOAD_BYTES=26214400

# MinIO (only used if STORAGE_DRIVER=minio)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_minio_password
MINIO_BUCKET=chat-vds

# Voice (mediasoup SFU). MEDIASOUP_ANNOUNCED_IP MUST be your VDS public IPv4 in
# production — clients dial UDP directly to this IP. RTC port range must be
# opened in your VDS firewall (default 40000-40100/udp+tcp).
MEDIASOUP_ANNOUNCED_IP=
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40100

# coturn (TURN/STUN) credentials. Optional — used as TURN fallback for clients
# behind hard NATs/symmetric firewalls. Leave defaults to disable TURN.
COTURN_USER=chatvds
COTURN_PASSWORD=CHANGE_ME_coturn_password
COTURN_REALM=chat.example.com
