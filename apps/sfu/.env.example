NODE_ENV=development
PORT=3002
HOST=0.0.0.0

# Reuses API's DB/Redis.
DATABASE_URL=postgresql://chatvds:chatvds@localhost:5432/chatvds?schema=public
REDIS_URL=redis://localhost:6379

# MUST match apps/api JWT_SECRET (>=32 chars).
JWT_SECRET=dev-secret-do-not-use-in-prod-please-rotate-32

CORS_ORIGIN=http://localhost:5173

# Mediasoup. Set ANNOUNCED_IP to your VDS public IPv4 in production.
# In local dev with the browser on the same machine, leave empty.
MEDIASOUP_ANNOUNCED_IP=
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40100
MEDIASOUP_LOG_LEVEL=warn
