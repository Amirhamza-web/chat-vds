NODE_ENV=development
PORT=3001
HOST=0.0.0.0

DATABASE_URL=postgresql://chatvds:chatvds@localhost:5432/chatvds?schema=public
REDIS_URL=redis://localhost:6379

# MUST be at least 32 characters in production. Generate with: openssl rand -base64 48
JWT_SECRET=dev-only-jwt-secret-change-me-please-32-chars-minimum
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

CORS_ORIGIN=http://localhost:5173

# Storage driver: 'local' (default, files on disk) or 'minio' (S3-compatible)
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:3001

# Used only when STORAGE_DRIVER=minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=chat-vds
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

MAX_UPLOAD_BYTES=26214400

# Web Push (VAPID) — optional. Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com
